{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "../dist/server",
    "rootDir": "src",
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "isolatedModules": false,
    "allowImportingTsExtensions": false,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
